#!/bin/sh
instances="$(curl https://cloud.lambda.ai/api/v1/instances -s -u "$LAMBDA_API_KEY" |
	jq -r '.data[] | [
		"ubuntu@\(.ip)",
		"ubuntu@\(.ip)",
		.status,
		.instance_type.description,
		.region.description,
		.instance_type.price_cents_per_hour,
		.ssh_key_names[]
	] | @tsv')"

if [ "$instances" = "" ]; then
	echo "No instances available" 1>&2
fi
